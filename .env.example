# OpenRouter API key — get yours at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use (default: anthropic/claude-sonnet-4-5)
# Other options: anthropic/claude-opus-4, openai/gpt-4o
MODEL=anthropic/claude-sonnet-4-5

# Admin panel: comma-separated emails that get the Admin tab (user mgmt, per-user
# model assignment, usage/cost). Defaults to dbarger@imb.org if unset.
ADMIN_EMAILS=dbarger@imb.org

# ── Verbatim Scripture providers (optional; each is independent) ────────────────
# When a key is set, its translations are fetched verbatim and (a) shown to the
# pastor and (b) injected into the AI prompts. Missing keys → those translations
# fall back to AI-quoted text. Coverage with all four below: ESV, NLT, KJV (EN);
# NVI, RVR1960, NTV, LBLA, RVA, RVR1909 (ES); plus LEB, LSB, ASV.
ESV_API_KEY=                 # api.esv.org (free, non-commercial) — ESV
NLT_API_KEY=                 # api.nlt.to (Tyndale) — NLT
APIBIBLE_API_KEY=            # rest.api.bible (free tier) — NVI, NTV, LBLA, RVR1909, KJV
BIBLIA_API_KEY=              # api.biblia.com (Faithlife) — RVR1960, RVA, KJV, LEB, LSB, ASV
